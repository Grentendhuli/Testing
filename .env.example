# LandlordBot - Production Environment
# Copy this file to .env.local and fill in your production keys

# ==========================================
# SendGrid - Transactional Emails (Recommended)
# Free tier: 100 emails/day
# Sign up at: https://sendgrid.com
# Create API key at: Settings > API Keys > Create API Key
# Required permissions: Mail Send
# ==========================================
VITE_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SENDGRID_FROM_EMAIL=noreply@landlordbot.live

# ==========================================
# Resend - Transactional Emails (Alternative)
# Get your API key at: https://resend.com
# ==========================================
VITE_RESEND_API_KEY=re_...

# Beta Feedback Form URL (Typeform/Google Forms)
VITE_FEEDBACK_FORM_URL=https://forms.gle/your-feedback-form

# ==========================================
# Cloudflare Worker - AI Assistant
# Deploy the worker from /cloudflare-worker directory
# Uses Cloudflare's free AI Workers tier (Llama 3.1)
# ==========================================
VITE_CLOUDFLARE_WORKER_URL=https://landlordbot-ai.your-account.workers.dev

# ==========================================
# Gemini API - AI Listing Generator
# Get your API key at: https://makersuite.google.com/app/apikey
# Free tier: 60 requests/minute
# ==========================================
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# NYC Open Data - Compliance Checks
# No API key required for public datasets
# Documentation: https://opendata.cityofnewyork.us/
# ==========================================
VITE_NYC_OPEN_DATA_BASE_URL=https://data.cityofnewyork.us/resource

# ==========================================
# Stripe - Payment Processing
# Get your keys at: https://stripe.com
# ==========================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_CONCIERGE_PRICE_ID=price_...

# ==========================================
# Supabase - Authentication & Database
# Get your keys at: https://supabase.com
# ==========================================
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# NOTE: Service role key should NEVER be exposed to client-side code.
# Use it only in server-side environments (Cloudflare Workers, API routes).
# If you need admin operations, create a secure backend API.

# ==========================================
# Rentometer API - Market Rent Comparables
# Get your free API key at: https://www.rentometer.com/api
# ==========================================
VITE_RENTOMETER_API_KEY=your_rentometer_api_key_here

# ==========================================
# Vapi AI Voice Calling - AI Advisor Calls
# Get your keys at: https://vapi.ai
# ==========================================
VITE_VAPI_API_KEY=your_vapi_api_key_here
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VITE_VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# ==========================================
# Sentry - Error Tracking & Monitoring
# Get your DSN at: https://sentry.io
# Free tier: 5,000 errors/month
# ==========================================
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=development

# ==========================================
# Application Configuration
# ==========================================
VITE_APP_NAME=LandlordBot Live
VITE_APP_VERSION=2.2.0
VITE_ENABLE_ANALYTICS=true
